{% extends 'base.html.twig' %}

{% block title %}Resend Logs{% endblock %}

{% block body %}
    <div style="max-width:650px;margin:48px auto;padding:40px 36px;background:linear-gradient(135deg,#f8fafc 0%,#e3e9f7 100%);border-radius:18px;box-shadow:0 4px 32px #0002;">
        <h1 style="text-align:center;color:#2d3a4a;margin-bottom:12px;font-size:2.2em;letter-spacing:1px;font-weight:700;">Resend Logs</h1>
        <p style="text-align:center;color:#4b5563;margin-bottom:26px;font-size:1.02em;">
            Requests are now processed as background jobs to avoid timeouts.
            <a href="{{ path('resend_jobs.view') }}" style="color:#2563eb;text-decoration:none;font-weight:600;">View jobs</a>
        </p>
        {% if error %}
            <div style="color: #fff; background: #e74c3c; padding: 10px; border-radius: 5px; margin-bottom: 16px;">Error: {{ error }}</div>
        {% endif %}
        <form method="post" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:22px;">
        <div>
            <label for="source" style="font-weight:700;font-size:1.13em;display:block;margin-bottom:6px;letter-spacing:0.5px;">Source:</label>
            <select name="source" id="source" style="width:100%;padding:10px 12px;border-radius:7px;border:1.5px solid #bfc9d9;background:#f6f8fa;font-size:1.08em;">
                {% for id, source in sources %}
                    <option value="{{ id }}" title="{{ source.metadata.description|e }}">{{ source.metadata.label }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="parser" style="font-weight:700;font-size:1.13em;display:block;margin-bottom:6px;letter-spacing:0.5px;">Parser:</label>
            <select name="parser" id="parser" style="width:100%;padding:10px 12px;border-radius:7px;border:1.5px solid #bfc9d9;background:#f6f8fa;font-size:1.08em;">
                {% for id, parser in parsers %}
                    <option value="{{ id }}" title="{{ parser.description|e }}">{{ parser.label }}</option>
                {% endfor %}
            </select>
        </div>
        <div style="margin-bottom:8px;">
    <div style="font-weight:700;font-size:1.13em;display:block;margin-bottom:6px;letter-spacing:0.5px;">Modifiers:</div>
    <div style="background:#f6f8fa;border:1.5px solid #bfc9d9;border-radius:8px;padding:14px 16px;">
    {% for id, modifier in modifiers %}
        <label style="font-weight:400;display:flex;align-items:center;gap:7px;margin-bottom:8px;" title="{{ modifier.description|e }}">
            <input type="checkbox" name="modifiers[]" value="{{ id }}"> {{ modifier.label }}
        </label>
    {% endfor %}
</div>
</div>
        <div id="filter-group" style="margin-bottom:8px;">
    <div style="font-weight:700;font-size:1.13em;display:block;margin-bottom:6px;letter-spacing:0.5px;">Filter:</div>
    <div style="background:#f6f8fa;border:1.5px solid #bfc9d9;border-radius:8px;padding:14px 16px;">
        <textarea name="filter" id="filter" rows="3" required style="width:100%;background:#f6f8fa;border:none;resize:vertical;"></textarea>
    </div>
</div>
        <script>
            // Dynamically build fileSources from sources variable
            const fileSources = [
                {% for id, source in sources %}
                    {% if source.is_file %}'{{ id }}',{% endif %}
                {% endfor %}
            ];
            const sourceSelect = document.getElementById('source');
            const filterGroup = document.getElementById('filter-group');
            function updateFilterInput() {
                const selected = sourceSelect.value;
                filterGroup.innerHTML = '<label for="filter" style="font-weight:700;font-size:1.13em;display:block;margin-bottom:6px;letter-spacing:0.5px;">Filter:</label>' +
                    (fileSources.includes(selected)
                        ? '<input type="file" name="file" id="filter" style="width:100%;background:#f6f8fa;border:none;padding:8px 0;">'
                        : '<div style="background:#f6f8fa;border:1.5px solid #bfc9d9;border-radius:8px;padding:14px 16px;"><textarea name="filter" id="filter" rows="3" required style="width:100%;background:#f6f8fa;border:none;resize:vertical;"></textarea></div>');
            }
            sourceSelect.addEventListener('change', updateFilterInput);
            document.addEventListener('DOMContentLoaded', updateFilterInput);
        </script>
        <div>
            <button type="submit" style="background:linear-gradient(90deg,#4f8cff 0%,#1cb5e0 100%);color:#fff;padding:12px 38px;border:none;border-radius:8px;font-size:1.13em;cursor:pointer;box-shadow:0 2px 8px #1cb5e033;transition:background 0.2s;font-weight:600;letter-spacing:0.5px;">Resend Logs</button>
        </div>
    </form>
{% endblock %}